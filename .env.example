# === 火山引擎主账号（jimeng 文生图 + 录音文件识别 ASR）===
VOLC_AK=your_access_key
VOLC_SK=your_secret_key
VOLC_REGION=cn-north-1
VOLC_REQ_KEY=jimeng_t2i_v40

# === 火山方舟（豆包文字模型，用于改写口播为贴图脚本 + ASR 校对）===
ARK_API_KEY=your_ark_api_key
ARK_MODEL=doubao-seed-1-6-250615

# === 微信公众号（贴图发布）===
WECHAT_APP_ID=wxXXXXXXXXXXXXXXXX
WECHAT_APP_SECRET=your_app_secret
# API 代理（华为云固定 IP 解决白名单），自部署也可填 https://api.weixin.qq.com
WECHAT_API_BASE=http://121.36.105.43:18900/wechat-api

# === ilinkai CloudBot（微信主动推送通知）===
# 在腾讯 https://ilinkai.weixin.qq.com 创建机器人后获取
ILINK_BOT_TOKEN=xxx@im.bot:xxxxxxxxxxxx
ILINK_BOT_ACCOUNT=xxx@im.bot
ILINK_USER_ID=oYourUserId@im.wechat

# === 火山 ASR（可选，未配置时 fallback 到本地 Whisper）===
# VOLC_ASR_APP_KEY=
# VOLC_ASR_ACCESS_KEY=

# === 配置 ===
MAX_CARDS=8
COVER_RATIO=3:4
BRAND_NAME=你的品牌名
WHISPER_MODEL=base
